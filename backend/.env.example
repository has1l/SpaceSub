DATABASE_URL="postgresql://spacesub:spacesub@localhost:5432/spacesub?schema=public"
JWT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:5174/api/auth/yandex/callback
PORT=3000
FRONTEND_URL=http://localhost:5174
FLEX_BANK_BASE_URL=http://localhost:3001
FLEX_BANK_TIMEOUT_MS=8000
FLEX_BANK_OAUTH_CLIENT_ID=
FLEX_BANK_OAUTH_CLIENT_SECRET=
FLEX_BANK_OAUTH_REDIRECT_URI=http://localhost:5174/api/bank-integration/flex/callback
TOKEN_ENCRYPTION_KEY=
# When using LocalTunnel, run: ./scripts/setup-tunnel.sh <name>.loca.lt
# YANDEX_REDIRECT_URI=https://<name>.loca.lt/api/auth/yandex/callback
# FRONTEND_URL=https://<name>.loca.lt
# FLEX_BANK_OAUTH_REDIRECT_URI=https://<name>.loca.lt/api/bank-integration/flex/callback
#
# When deploying to Vercel (frontend only):
# FRONTEND_URL=https://your-app.vercel.app
# YANDEX_REDIRECT_URI must point to the deployed backend, not Vercel
#
# ── Railway deployment ──
# DATABASE_URL is auto-set by Railway PostgreSQL plugin
# PORT is auto-set by Railway
# All other variables must be set in Railway dashboard:
# JWT_SECRET=<strong-random-secret>
# YANDEX_CLIENT_ID=<your-yandex-app-id>
# YANDEX_CLIENT_SECRET=<your-yandex-app-secret>
# YANDEX_REDIRECT_URI=https://<railway-url>/api/auth/yandex/callback
# FRONTEND_URL=https://<your-app>.vercel.app
# FLEX_BANK_OAUTH_CLIENT_ID=<your-flex-bank-client-id>
# FLEX_BANK_OAUTH_CLIENT_SECRET=<your-flex-bank-client-secret>
# FLEX_BANK_BASE_URL=https://hearty-education-production-908e.up.railway.app
# FLEX_BANK_OAUTH_REDIRECT_URI=https://<railway-url>/api/bank-integration/flex/callback
# TOKEN_ENCRYPTION_KEY=<64-char-hex-string>
