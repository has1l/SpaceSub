generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["mockbank"]
}

model User {
  id        String    @id @default(uuid())
  yandexId  String    @unique @map("yandex_id")
  email     String
  name      String
  createdAt DateTime  @default(now()) @map("created_at")

  accounts      Account[]
  subscriptions UserSubscription[]

  @@map("users")
  @@schema("mockbank")
}

enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER

  @@schema("mockbank")
}

enum TransactionCategory {
  SUBSCRIPTIONS
  SUPERMARKETS
  TRANSFERS
  DIGITAL_SERVICES
  INVESTMENTS
  TRANSPORT
  RESTAURANTS
  HEALTH
  OTHER

  @@schema("mockbank")
}

model Account {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  currency       String   @default("RUB")
  initialBalance Float    @default(0) @map("initial_balance")
  createdAt      DateTime @default(now()) @map("created_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  recurringPayments RecurringPayment[]
  userSubscriptions UserSubscription[]

  @@map("accounts")
  @@schema("mockbank")
}

model Transaction {
  id          String              @id @default(uuid())
  accountId   String              @map("account_id")
  date        DateTime
  amount      Float
  currency    String              @default("RUB")
  description String
  merchant    String?
  type        TransactionType     @default(EXPENSE)
  category    TransactionCategory @default(OTHER)
  createdAt   DateTime            @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, date])
  @@map("transactions")
  @@schema("mockbank")
}

enum RecurringPaymentStatus {
  ACTIVE
  CANCELLED

  @@schema("mockbank")
}

model RecurringPayment {
  id             String                 @id @default(uuid())
  accountId      String                 @map("account_id")
  merchant       String
  amount         Float
  currency       String                 @default("RUB")
  category       TransactionCategory    @default(SUBSCRIPTIONS)
  periodDays     Int                    @default(30) @map("period_days")
  nextChargeDate DateTime               @map("next_charge_date")
  status         RecurringPaymentStatus @default(ACTIVE)
  cancelledAt    DateTime?              @map("cancelled_at")
  createdAt      DateTime               @default(now()) @map("created_at")

  account          Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userSubscription UserSubscription?

  @@map("recurring_payments")
  @@schema("mockbank")
}

enum UserSubscriptionStatus {
  ACTIVE
  CANCELLED

  @@schema("mockbank")
}

model ServiceCatalog {
  id          String              @id @default(uuid())
  name        String
  merchant    String              @unique
  description String
  logoUrl     String?             @map("logo_url")
  amount      Float
  currency    String              @default("RUB")
  periodDays  Int                 @default(30) @map("period_days")
  category    TransactionCategory @default(SUBSCRIPTIONS)
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")

  subscriptions UserSubscription[]

  @@map("service_catalog")
  @@schema("mockbank")
}

model UserSubscription {
  id                 String                 @id @default(uuid())
  userId             String                 @map("user_id")
  serviceId          String                 @map("service_id")
  accountId          String                 @map("account_id")
  recurringPaymentId String?                @unique @map("recurring_payment_id")
  status             UserSubscriptionStatus @default(ACTIVE)
  subscribedAt       DateTime               @default(now()) @map("subscribed_at")
  cancelledAt        DateTime?              @map("cancelled_at")
  createdAt          DateTime               @default(now()) @map("created_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  service          ServiceCatalog    @relation(fields: [serviceId], references: [id])
  account          Account           @relation(fields: [accountId], references: [id])
  recurringPayment RecurringPayment? @relation(fields: [recurringPaymentId], references: [id])

  @@unique([userId, serviceId])
  @@map("user_subscriptions")
  @@schema("mockbank")
}

model ConnectionCode {
  id             String   @id @default(uuid())
  codeHash       String   @unique @map("code_hash")
  encryptedToken String   @map("encrypted_token")
  expiresAt      DateTime @map("expires_at")
  used           Boolean  @default(false)
  attempts       Int      @default(0)
  flexUserId     String   @map("flex_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("connection_codes")
  @@schema("mockbank")
}
