generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  yandexId  String    @unique @map("yandex_id")
  email     String
  name      String
  createdAt DateTime  @default(now()) @map("created_at")

  accounts Account[]

  @@map("users")
}

enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER
}

enum TransactionCategory {
  SUBSCRIPTIONS
  SUPERMARKETS
  TRANSFERS
  DIGITAL_SERVICES
  INVESTMENTS
  TRANSPORT
  RESTAURANTS
  HEALTH
  OTHER
}

model Account {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  currency       String   @default("RUB")
  initialBalance Float    @default(0) @map("initial_balance")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("accounts")
}

model Transaction {
  id          String              @id @default(uuid())
  accountId   String              @map("account_id")
  date        DateTime
  amount      Float
  currency    String              @default("RUB")
  description String
  merchant    String?
  type        TransactionType     @default(EXPENSE)
  category    TransactionCategory @default(OTHER)
  createdAt   DateTime            @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, date])
  @@map("transactions")
}

model ConnectionCode {
  id             String   @id @default(uuid())
  codeHash       String   @unique @map("code_hash")
  encryptedToken String   @map("encrypted_token")
  expiresAt      DateTime @map("expires_at")
  used           Boolean  @default(false)
  attempts       Int      @default(0)
  flexUserId     String   @map("flex_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("connection_codes")
}
