# ── Required ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/mockbank?schema=public"
JWT_SECRET=change-me-in-production
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
TOKEN_ENCRYPTION_KEY=   # 64 hex chars (32 bytes) for AES-256-GCM

# ── Required (URLs) ──────────────────────────────────────────────
# Must match the registered redirect URI in Yandex OAuth app settings
YANDEX_REDIRECT_URI=https://YOUR_MOCK_BANK_DOMAIN/auth/yandex/callback

# Frontend URL — used for OAuth callback redirect to flex-bank-frontend
FRONTEND_URL=https://YOUR_FLEX_BANK_FRONTEND_URL/bank

# ── Optional ─────────────────────────────────────────────────────
PORT=3001   # Railway sets this automatically

# ── Railway deployment ───────────────────────────────────────────
# On Railway, set these as service variables:
#   DATABASE_URL          — from Railway PostgreSQL plugin
#   JWT_SECRET            — strong random string
#   YANDEX_CLIENT_ID      — from Yandex Developer Console
#   YANDEX_CLIENT_SECRET  — from Yandex Developer Console
#   YANDEX_REDIRECT_URI   — https://<railway-domain>/auth/yandex/callback
#   FRONTEND_URL          — https://<flex-bank-frontend-domain>/bank
#   TOKEN_ENCRYPTION_KEY  — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
